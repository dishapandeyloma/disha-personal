# EmailJS Configuration
# 1. Sign up at https://www.emailjs.com/
# 2. Add an Email Service and get your Service ID
# 3. Create an Email Template and get your Template ID
# 4. Get your Public Key from Account Settings

NUXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
NUXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
NUXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
